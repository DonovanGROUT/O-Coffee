<!-- Section supérieure (hero) de la page -->
<%- include('partials/hero', { backgroundImage: './images/about.webp' , title: 'Découvrez nos cafés d\' exception',
    titleClass: 'hero-title' }) %>

    <section class="home-intro">
        <p class="home-description">Des grains soigneusement sélectionnés pour une expérience gustative unique.</p>
    </section>

    <!-- Section Nouveautés -->
    <section class="nouveautes">
        <h2 class="section-title">Nouveautés</h2>
        <%- include('partials/product-grid', { coffees: coffees }) %>
    </section>
    <!-- Bouton "Voir le catalogue" -->
    <div class="catalogue-button-container">
        <a href="/catalogue" class="btn btn-primary">Voir le catalogue</a>
    </div>
    <!-- Formulaire de contact -->
    <section id="contact">
        <h2>Contactez-nous</h2>
        <div id="error-message" class="hidden"></div>
        <div id="success-message" class="hidden"></div>
        <form id="contact-form">
            <label for="name">Nom :</label>
            <input type="text" id="name" name="name" required placeholder="Votre nom">

            <label for="email">Email :</label>
            <input type="email" id="email" name="email" required placeholder="Votre adresse email">

            <label for="message">Message :</label>
            <textarea id="message" name="message" required placeholder="Votre message"></textarea>

            <button type="submit">Envoyer</button>
        </form>
    </section>